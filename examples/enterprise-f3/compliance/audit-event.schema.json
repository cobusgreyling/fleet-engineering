{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FleetAuditEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "agent_id", "authority", "task", "evidence"],
  "properties": {
    "event_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent_id": { "type": "string" },
    "authority": {
      "type": "object",
      "required": ["identity", "credential_scope"],
      "properties": {
        "identity": { "enum": ["claw", "assistant"] },
        "credential_scope": { "type": "string" },
        "invoked_by": { "type": "string" }
      }
    },
    "task": { "type": "string" },
    "evidence": {
      "type": "object",
      "required": ["trace_id"],
      "properties": {
        "trace_id": { "type": "string" },
        "trace_platform": { "type": "string" },
        "inbox_approval_id": { "type": "string" }
      }
    },
    "outcome": { "enum": ["success", "failure", "pending_approval"] }
  }
}